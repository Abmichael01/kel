# Kel's private local configuration. Copy this file to `.env` and fill it in
# (or just run `uv run kel-setup`, which writes `.env` for you). NEVER commit `.env`
# or a real key — this file holds placeholders only.

# ── Her brain ────────────────────────────────────────────────────────────────
# "gemini" = Google Gemini Live: cheaper audio, free key, the recommended choice.
# "openai" = OpenAI gpt-realtime (needs OPENAI_API_KEY below).
KEL_REALTIME_PROVIDER=gemini

# Required for the Gemini brain. Get a FREE key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Only used for long-term memory and the older push-to-talk voice mode.
# Leave blank on a Gemini setup — she just runs without memory until you add one.
OPENAI_API_KEY=

KEL_NAME=Kel

# ── Gemini voice ─────────────────────────────────────────────────────────────
KEL_GEMINI_REALTIME_MODEL=gemini-3.1-flash-live-preview
# Voices: Puck, Charon, Kore, Fenrir, Aoede, Leda, Orus, Zephyr.
KEL_GEMINI_VOICE=Leda
KEL_GEMINI_AFFECTIVE_DIALOG=false
KEL_TONE_CUES_ENABLED=true

# ── Audio ────────────────────────────────────────────────────────────────────
# Leave blank for system defaults. Run `uv run python -m sounddevice` to list devices.
KEL_AUDIO_INPUT_DEVICE=
KEL_AUDIO_OUTPUT_DEVICE=
# Half-duplex mutes the mic while she talks (stops her hearing her own echo). Keep true
# unless you use headphones and want to interrupt her by voice.
KEL_REALTIME_HALF_DUPLEX=true
KEL_REALTIME_ECHO_CANCEL=false

# ── Vision (camera) ──────────────────────────────────────────────────────────
# She only takes a photo when she calls her `look` tool. Degrades gracefully with no camera.
KEL_VISION_ENABLED=true
KEL_CAMERA_DEVICE=0
KEL_VISION_MAX_WIDTH=768

# She can also see your SCREEN via a `see_screen` tool (needs `grim`, a Wayland/wlroots
# screenshot tool). Off by default. Wider = sharper text she can read, but costs more tokens.
KEL_SCREEN_ENABLED=false
KEL_SCREEN_MAX_WIDTH=1280

# ── Long-term memory ─────────────────────────────────────────────────────────
# Needs an OpenAI key (embeddings). Auto-disabled if OPENAI_API_KEY is blank.
KEL_MEMORY_ENABLED=true
KEL_MEMORY_AUTO_CAPTURE=true
KEL_MEMORY_PATH=kel_memory.json
KEL_MEMORY_TOP_K=5

# ── Wake word ────────────────────────────────────────────────────────────────
# Say "Kel, pay attention" to wake, "Kel, at ease" to sleep. Off by default because it
# needs a local Vosk model — `uv run kel-setup` can download it and switch this on.
KEL_WAKE_ENABLED=false
KEL_WAKE_BACKEND=vosk
KEL_WAKE_VOSK_MODEL_PATH=
KEL_WAKE_PHRASES_SLEEP=at ease
KEL_WAKE_SENSITIVITY=0.5
KEL_WAKE_AUTO_SLEEP_SECONDS=90
KEL_WAKE_QUICK_SLEEP_SECONDS=30
KEL_WAKE_GREETING=Yeah?
KEL_WAKE_FAREWELL=Alright, later.

# ── On-screen face ───────────────────────────────────────────────────────────
# The kel-face window (glowing eyes + mouth). Needs the `face` extra (pygame). Windowed
# by default so it doesn't surprise you with fullscreen.
KEL_FACE_ENABLED=true
KEL_FACE_AUTOSTART=true
KEL_FACE_FULLSCREEN=false
KEL_FACE_HOST=127.0.0.1
KEL_FACE_PORT=8765

# ── Computer control (OFF by default — she can run commands on this machine) ──
# Browser opening is low risk and on. Shell/keyboard control is powerful; only turn it
# on if you trust this setup. The catastrophic-command tripwire stays on regardless.
KEL_BROWSER_ENABLED=true
KEL_SHELL_ENABLED=false
KEL_SHELL_BLOCK_DANGEROUS=true
KEL_SHELL_TIMEOUT_SECONDS=20
KEL_KEYBOARD=wtype
KEL_TERMINAL=

# ── Robot body (Arduino over USB) ────────────────────────────────────────────
# Off by default. `uv run kel-setup` turns it on if it detects a board. Blank port = auto.
KEL_BODY_ENABLED=false
KEL_BODY_PORT=
KEL_BODY_SERVO_PIN=9

# ── OpenAI-only extras (text chat `kel` and push-to-talk `kel-voice`) ─────────
# These modes always use OpenAI; ignored on a Gemini-only setup.
KEL_OPENAI_MODEL=gpt-5.4-mini
KEL_EMBEDDING_MODEL=text-embedding-3-small
